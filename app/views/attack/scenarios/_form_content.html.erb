<%= form_with(model: scenario, url: url, local: false, data: { controller: "nested-form", nested_form_scenario_id_value: scenario.id || "new" }) do |form| %>
  <div class="mb-4">
    <%= form.label :name, class: "form-label h5" do %>名前<span class="text-danger ms-1">*</span><% end %>
    <%= form.text_field :name, class: "form-control mb-4", required: true %>
  </div>

  <div id="details-container" data-nested-form-target="detailsContainer">
    <%= form.fields_for :details do |detail_form| %>
      <%= render 'detail_fields', detail_form: detail_form %>
    <% end %>
  </div>

  <div class="d-flex justify-content-center">
    <div class="ps-2 pe-2">
      <%= form.submit submit_text, class: "btn btn-primary", style: "width: 8rem;" %>
    </div>
    <div class="ps-2 pe-2">
      <%= link_to "キャンセル", cancel_path, class: "btn btn-secondary", style: "width: 8rem;" %>
    </div>
  </div>
<% end %>
