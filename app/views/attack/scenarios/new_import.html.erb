<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2><%= Attack::Scenario.model_name.human %>のインポート</h2>
  </div>

  <div class="card">
    <div class="card-body">
      <%= form_with url: import_attack_scenarios_path, multipart: true, local: true do |form| %>
        <div class="mb-3">
          <%= form.label :file, "JSONファイル", class: "form-label" %>
          <%= form.file_field :file, class: "form-control", accept: ".json" %>
          <div class="form-text">
            JSONファイルを指定してください。ファイル名がシナリオ名になります。
          </div>
        </div>

        <div>
          <%= form.submit "インポート", class: "btn btn-primary" %>
          <%= link_to "キャンセル", attack_scenarios_path, class: "btn btn-outline-secondary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
