<%# 完了時: 防衛方針の詳細情報を表示 %>
<%# policy: 防衛方針 %>

<div class="card mb-4">
  <div class="card-body">
    <h6 class="card-title mb-2 fw-bold">基本情報</h6>
    <div class="row mb-2">
      <div class="col-md-3">
        名前:
      </div>
      <div class="col-md-9">
        <%= policy.name.presence || "方針 ##{policy.id}" %>
      </div>
    </div>
    <% if policy.source_policy.present? %>
      <div class="row mb-2">
        <div class="col-md-3">
          初期防衛方針:
        </div>
        <div class="col-md-9">
          <%= link_to policy.source_policy.name.presence || "方針 ##{policy.source_policy.id}", defense_initial_policy_path(policy.source_policy) %>
        </div>
      </div>
    <% end %>
    <div class="row mb-2">
      <div class="col-md-3">
        作成日時:
      </div>
      <div class="col-md-9">
        <%= l(policy.created_at, format: :compact) %>
        <% if policy.execution_time %>
          <span class="ms-3 text-muted">⏱️ <%= format_duration(policy.execution_time) %></span>
        <% end %>
      </div>
    </div>
    <% if policy.initial? %>
      <div class="row">
        <div class="col-md-3">
          拡張された方針:
        </div>
        <div class="col-md-9">
          <% if policy.extended_policies.count > 0 %>
            <%= link_to "#{policy.extended_policies.count}件の拡張された方針があります", defense_policies_path(source_policy_id: policy.id) %>
          <% else %>
            <span class="text-muted">この初期方針はまだ拡張に利用されていません。攻撃結果レポートがあれば、攻撃結果レポートから拡張を行うことができます。</span>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<div class="card mb-4">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h5 class="mb-0">防衛方針内容</h5>
    <span class="text-muted">全<%= policy.contents.size %>件</span>
  </div>
  <div class="card-body">
    <% if policy.contents.any? %>
      <ol>
        <% policy.contents.each do |content| %>
          <li class="mb-2"><%= content %></li>
        <% end %>
      </ol>
    <% else %>
      <p class="text-muted">防衛方針がまだ登録されていません。</p>
    <% end %>
  </div>
</div>
