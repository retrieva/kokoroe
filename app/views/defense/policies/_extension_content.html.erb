<div class="row mb-3">
  <div class="col-md-3">
    <strong><%= Defense::Policy.human_attribute_name(:started_at) %>:</strong>
  </div>
  <div class="col-md-9">
    <% if policy.started_at %>
      <%= l policy.started_at, format: :compact %>
    <% else %>
      <span class="text-muted">-</span>
    <% end %>
  </div>
</div>

<div class="row mb-3">
  <div class="col-md-3">
    <strong>ステータス:</strong>
  </div>
  <div class="col-md-9">
    <span class="badge bg-<%= policy.completed? ? 'success' : policy.failed? ? 'danger' : policy.running? ? 'primary' : 'secondary' %>">
      <%= policy.status_i18n %>
    </span>
  </div>
</div>

<div class="row mb-3">
  <div class="col-md-3">
    <strong><%= Defense::Policy.human_attribute_name(:completed_at) %>:</strong>
  </div>
  <div class="col-md-9">
    <% if policy.completed_at || policy.failed_at %>
      <%= l(policy.completed_at || policy.failed_at, format: :compact) %>
      <% if policy.execution_time %>
        <span class="ms-3 text-muted">⏱️ <%= format_duration(policy.execution_time) %></span>
      <% end %>
    <% else %>
      <span class="text-muted">-</span>
    <% end %>
  </div>
</div>
